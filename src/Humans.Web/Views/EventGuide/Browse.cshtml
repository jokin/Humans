@model Humans.Web.Models.BrowseViewModel
@{
    ViewData["Title"] = "Browse Events";
}

<h2 class="mb-3">Browse Events</h2>

@if (Model.TimeZoneId != null)
{
    <p class="text-muted small">
        <i class="fa-solid fa-clock me-1"></i>All times in <strong>@Model.TimeZoneId</strong>
    </p>
}

<form method="get" asp-action="Browse" class="card mb-4">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small mb-1">Day</label>
                <select name="day" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">All days</option>
                    @foreach (var d in Model.Days)
                    {
                        <option value="@d.DayOffset" selected="@(Model.FilterDay == d.DayOffset)">@d.Label</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Category</label>
                <select name="categoryId" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">All categories</option>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Id" selected="@(Model.FilterCategoryId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Camp</label>
                <select name="campId" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">All camps</option>
                    @foreach (var c in Model.Camps)
                    {
                        <option value="@c.Id" selected="@(Model.FilterCampId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-1">Search</label>
                <input type="text" name="q" value="@Model.SearchQuery" class="form-control form-control-sm"
                       placeholder="Search title or description..." />
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <div class="form-check">
                    <input type="checkbox" name="favouritesOnly" value="true" class="form-check-input"
                           id="favouritesOnly" checked="@Model.FavouritesOnly" onchange="this.form.submit()" />
                    <label class="form-check-label small" for="favouritesOnly">
                        <i class="fa-solid fa-heart text-danger"></i> Only
                    </label>
                </div>
                <button type="submit" class="btn btn-sm btn-primary">
                    <i class="fa-solid fa-search"></i>
                </button>
            </div>
            @if (Model.FilterDay.HasValue || Model.FilterCategoryId.HasValue || Model.FilterCampId.HasValue
                 || !string.IsNullOrEmpty(Model.SearchQuery) || Model.FavouritesOnly)
            {
                <div class="col-md-1 d-flex align-items-end">
                    <a asp-action="Browse" class="btn btn-sm btn-outline-secondary">Clear</a>
                </div>
            }
        </div>
    </div>
</form>

@if (Model.DayGroups.Count == 0)
{
    <div class="alert alert-secondary">
        No events found. Try adjusting your filters.
    </div>
}
else
{
    @foreach (var dayGroup in Model.DayGroups)
    {
        <h4 class="mt-4 mb-3">@dayGroup.DayLabel</h4>
        <div class="list-group mb-3">
            @foreach (var item in dayGroup.Items)
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <strong>@item.Title</strong>
                            <span class="badge bg-secondary ms-1">@item.CategoryName</span>
                        </div>
                        <form method="post" asp-action="ToggleFavourite" asp-route-eventId="@item.EventId"
                              asp-route-day="@Model.FilterDay" asp-route-categoryId="@Model.FilterCategoryId"
                              asp-route-campId="@Model.FilterCampId" asp-route-q="@Model.SearchQuery"
                              asp-route-favouritesOnly="@Model.FavouritesOnly" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm @(item.IsFavourited ? "btn-danger" : "btn-outline-danger")"
                                    title="@(item.IsFavourited ? "Remove from favourites" : "Add to favourites")">
                                <i class="fa-solid @(item.IsFavourited ? "fa-heart" : "fa-heart")"></i>
                            </button>
                        </form>
                    </div>
                    <div class="mt-1 small text-muted">
                        <i class="fa-solid fa-clock me-1"></i>@item.StartAt.ToString("HH:mm") — @item.StartAt.AddMinutes(item.DurationMinutes).ToString("HH:mm")
                        (@item.DurationMinutes min)
                        @if (item.CampName != null)
                        {
                            <text> &middot; <i class="fa-solid fa-campground me-1"></i>@item.CampName</text>
                        }
                        @if (item.VenueName != null)
                        {
                            <text> &middot; <i class="fa-solid fa-location-dot me-1"></i>@item.VenueName</text>
                        }
                        @if (!string.IsNullOrEmpty(item.LocationNote))
                        {
                            <text> &middot; @item.LocationNote</text>
                        }
                        @if (item.SubmitterName != null)
                        {
                            <text> &middot; <i class="fa-solid fa-user me-1"></i>@item.SubmitterName</text>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(item.Description))
                    {
                        <p class="mt-2 mb-0 small">@item.Description</p>
                    }
                </div>
            }
        </div>
    }
}

<div class="mt-3 d-flex gap-2">
    <a asp-action="Schedule" class="btn btn-outline-secondary">
        <i class="fa-solid fa-calendar me-1"></i>My Schedule
    </a>
    <a asp-action="MySubmissions" class="btn btn-outline-secondary">
        <i class="fa-solid fa-list me-1"></i>My Submissions
    </a>
</div>
